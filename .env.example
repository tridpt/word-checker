# Cau hinh LLM (TUY CHON) cho tinh nang kiem tra chinh ta bang AI.
# Copy file nay thanh .env va dien API key. De trong thi tinh nang AI se TAT.
#
# Theo chuan OpenAI-compatible. Vi du Groq (free, nhanh):
#   Dang ky key tai https://console.groq.com
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile

# Vi du dung Google Gemini (free):
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_API_KEY=...
# LLM_MODEL=gemini-2.0-flash

# Vi du dung OpenAI:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=...
# LLM_MODEL=gpt-4o-mini
